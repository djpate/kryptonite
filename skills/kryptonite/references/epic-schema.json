{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KryptoniteEpic",
  "description": "Schema for epic.json — the per-epic metadata, decisions, scope history, technical context, and design direction. Stories live in state.json (story-schema.json); this file holds everything else the interview produces.",
  "type": "object",
  "required": ["name", "slug", "description", "status", "current_phase", "kryptonite_version", "created_at"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["active", "completed"] },
    "current_phase": { "type": "integer", "minimum": 1, "maximum": 12 },
    "kryptonite_version": {
      "type": "string",
      "description": "Version of kryptonite that created this epic. Used by the validator to apply the right schema for the epic's vintage."
    },
    "created_at": { "type": "string" },
    "completed_at": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
    "supersedes": {
      "type": "string",
      "description": "Optional slug of a prior epic this one replaces."
    },
    "parties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "auth": { "type": "string" }
        }
      },
      "description": "Actors / roles defined in Phase 4."
    },
    "decisions": {
      "type": "array",
      "description": "Architecture Decision Records captured during Phase 3 (gap analysis) and any later phase that produces architectural rulings. Lifted into spec.json.architecture.decisions[] verbatim during Phase 10. Same shape as spec-schema.json's decisions, plus two extension fields (source_phase, related_stories) used for traceability.",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "context", "choice", "consequences"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ADR-\\d{3}$",
            "description": "ADR identifier, e.g. 'ADR-001'."
          },
          "title": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["accepted", "superseded", "deprecated"]
          },
          "context": {
            "type": "string",
            "minLength": 10,
            "description": "The situation that forced this decision."
          },
          "choice": {
            "type": "string",
            "minLength": 10,
            "description": "The option that was selected."
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["option", "rejected_because"],
              "properties": {
                "option": { "type": "string", "minLength": 1 },
                "rejected_because": { "type": "string", "minLength": 10 }
              }
            }
          },
          "consequences": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 10 }
          },
          "source_phase": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12,
            "description": "Which phase produced this decision. Useful for traceability and resume."
          },
          "related_stories": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^US-\\d{3,}[a-z]?$"
            },
            "description": "Story IDs the decision affects. Spec rendering can group ADRs near their stories."
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "description": "Unresolved questions captured during Phase 3 (or later) that need answers before or during execution. Lifted into spec.json.open_questions[] verbatim during Phase 10.",
      "items": {
        "type": "object",
        "required": ["id", "question", "context", "proposed_answer", "blocks"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^OQ-\\d{3}$"
          },
          "question": { "type": "string", "minLength": 10 },
          "context": { "type": "string", "minLength": 10 },
          "proposed_answer": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "type": "null" }
            ]
          },
          "blocks": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "description": "Story IDs or section names that cannot proceed until this is resolved."
          },
          "source_phase": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          }
        }
      }
    },
    "scope_history": {
      "type": "array",
      "description": "Append-only log of scope changes after Phase 5 spike findings or any later re-scope. Each entry records the trigger and the delta (added/removed/modified/deferred stories). The current state always lives in state.json — this is the change log, not the snapshot.",
      "items": {
        "type": "object",
        "required": ["phase", "trigger"],
        "properties": {
          "phase": { "type": "integer", "minimum": 1, "maximum": 12 },
          "timestamp": { "type": "string" },
          "trigger": { "type": "string", "minLength": 1 },
          "added": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "removed": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "modified": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "fields", "reason"],
              "properties": {
                "id": { "type": "string", "pattern": "^US-\\d{3,}[a-z]?$" },
                "fields": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "reason": { "type": "string", "minLength": 1 }
              }
            }
          },
          "deferred": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "technical_context": {
      "type": "object",
      "description": "Phase 7 output. Test approach, NFRs, infrastructure integrations, and architectural patterns. At least one of testing/non_functional/infrastructure/patterns must be populated for the Phase 7 gate to pass.",
      "properties": {
        "testing": {
          "type": "object",
          "minProperties": 1,
          "properties": {
            "backend":  { "$ref": "#/$defs/test_layer" },
            "frontend": { "$ref": "#/$defs/test_layer" },
            "e2e":      { "$ref": "#/$defs/test_layer" },
            "other":    { "type": "array", "items": { "$ref": "#/$defs/test_layer" } }
          }
        },
        "non_functional": {
          "type": "object",
          "minProperties": 1,
          "properties": {
            "performance":   { "type": "array", "items": { "$ref": "#/$defs/nfr_target" } },
            "concurrency":   { "type": "array", "items": { "$ref": "#/$defs/nfr_target" } },
            "reliability":   { "type": "array", "items": { "$ref": "#/$defs/nfr_target" } },
            "observability": { "type": "array", "items": { "$ref": "#/$defs/nfr_target" } },
            "security":      { "type": "array", "items": { "$ref": "#/$defs/nfr_target" } },
            "accessibility": { "type": "array", "items": { "$ref": "#/$defs/nfr_target" } },
            "browser_support": { "type": "string" },
            "cost":          { "type": "array", "items": { "$ref": "#/$defs/nfr_target" } },
            "i18n": {
              "type": "object",
              "properties": {
                "launch_locales": { "type": "array", "items": { "type": "string" } },
                "notes": { "type": "string" }
              }
            }
          }
        },
        "infrastructure": {
          "type": "object",
          "minProperties": 1,
          "properties": {
            "integrate_with": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["system", "purpose"],
                "properties": {
                  "system": { "type": "string", "minLength": 1 },
                  "purpose": { "type": "string", "minLength": 1 },
                  "interface": { "type": "string" }
                }
              }
            },
            "do_not_integrate": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["system", "reason"],
                "properties": {
                  "system": { "type": "string", "minLength": 1 },
                  "reason": { "type": "string", "minLength": 1 }
                }
              }
            },
            "gating": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["layer", "rule"],
                "properties": {
                  "layer": { "type": "string", "minLength": 1 },
                  "rule": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "patterns": {
          "type": "object",
          "minProperties": 1,
          "properties": {
            "honor": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "avoid": { "type": "array", "items": { "type": "string", "minLength": 1 } }
          }
        },
        "notes": {
          "type": "array",
          "description": "Escape hatch for content that genuinely doesn't fit the four sub-objects. Use sparingly — recurring use means the schema needs another field.",
          "items": {
            "type": "object",
            "required": ["topic", "body"],
            "properties": {
              "topic": { "type": "string", "minLength": 1 },
              "body": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "design_direction": {
      "type": "object",
      "description": "Phase 8 output. Captures the visual DNA established by foundational mock approval. When `locked` is true, `shell_summary` must be a structured object — not free-form prose — so detail mocks can inherit deterministically and the spec can render the design system as data.",
      "properties": {
        "locked": { "type": "boolean" },
        "locked_after_phase": { "type": "string", "enum": ["foundational", "detail"] },
        "established_from": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "foundational_stories": {
          "type": "array",
          "items": { "type": "string", "pattern": "^US-\\d{3,}[a-z]?$" }
        },
        "detail_stories": {
          "type": "array",
          "items": { "type": "string", "pattern": "^US-\\d{3,}[a-z]?$" }
        },
        "approved_mocks": {
          "type": "array",
          "items": { "type": "string", "pattern": "^US-\\d{3,}[a-z]?$" }
        },
        "notes": { "type": "string" },
        "shell_summary": {
          "type": "object",
          "description": "Structured visual DNA — the design system as data. Required when locked === true.",
          "properties": {
            "nav": { "type": "string" },
            "header": { "type": "string" },
            "layout": { "type": "string" },
            "colors": {
              "type": "object",
              "properties": {
                "primary": { "type": "string" },
                "secondary": { "type": "string" },
                "surface": { "type": "string" },
                "bg": { "type": "string" },
                "text": { "type": "string" }
              }
            },
            "typography": { "type": "string" },
            "spacing": { "type": "string" },
            "components": { "type": "string" }
          },
          "minProperties": 1
        }
      },
      "if": {
        "properties": { "locked": { "const": true } },
        "required": ["locked"]
      },
      "then": {
        "required": ["shell_summary"]
      }
    },
    "findings": {
      "type": "array",
      "description": "Phase 12 execution discoveries. Agent-nominated, orchestrator-curated; escalations auto-capture. The durable home for what waves teach — replaces the ad-hoc state.deferred_findings[]. Resume builds its digest from this array. See references/execution-protocol.md (capture/curation/promotion) and references/storage-protocol.md (resume digest).",
      "items": {
        "type": "object",
        "required": ["id", "category", "audience", "wave_id", "summary", "resolution"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^WAVE\\d+-FINDING-\\d{3,}$",
            "description": "Stable id, scoped to the wave that produced the finding: WAVE<N>-FINDING-NNN."
          },
          "category": {
            "type": "string",
            "enum": ["process", "repo_gotcha", "spec_gap", "regression_risk", "deferred_defect"],
            "description": "process = fix-loop/infra lesson; repo_gotcha = runtime-discovered repo trap (promotion candidate); spec_gap = spec/plan ambiguity that forced a live decision (incl. NEEDS_CONTEXT); regression_risk = later waves must watch this (pairs with forward_to_waves); deferred_defect = a real defect intentionally deferred."
          },
          "audience": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["orchestrator", "coder", "gate", "human"] },
            "description": "Who should read this on resume. The digest filters sections by audience."
          },
          "wave_id": { "type": "string", "pattern": "^wave-\\d+$" },
          "source": { "type": "string", "description": "Provenance, e.g. 'wave-6 code-review (attempt 2)' or 'escalation: attempt-3 pause'." },
          "story": { "type": "string", "pattern": "^US-\\d{3,}[a-z]?$" },
          "repo": { "type": "string" },
          "file": { "type": "string" },
          "summary": { "type": "string", "minLength": 10 },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
          "resolution": {
            "type": "string",
            "enum": ["open", "fixed", "deferred", "dismissed", "promoted"],
            "description": "open = needs a decision/action; fixed = resolved in-epic (set commit); deferred = intentionally left for later; dismissed = reviewed, not a defect; promoted = written into repos.json conventions (set promotion_target)."
          },
          "owner_followup": { "type": "string", "description": "Concrete next action if resolution is open/deferred." },
          "commit": { "type": "string", "description": "Commit SHA when resolution is fixed." },
          "forward_to_waves": {
            "type": "array",
            "items": { "type": "string", "pattern": "^wave-\\d+$" },
            "description": "Regression-risk forwarding: the resume digest surfaces this finding to these waves' coders/gates."
          },
          "promotion_target": {
            "type": "string",
            "description": "If resolution=promoted: the repos.json conventions path it was written to, e.g. 'kmsat.conventions.test_data_gotchas'."
          },
          "created_at": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "test_layer": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "framework": { "type": "string" },
        "approach": { "type": "string" },
        "run_command": { "type": "string" },
        "conventions": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "nfr_target": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "metric": { "type": "string" },
        "dimension": { "type": "string" },
        "concern": { "type": "string" },
        "signal": { "type": "string" },
        "control": { "type": "string" },
        "scope": { "type": "string" },
        "lever": { "type": "string" },
        "target": { "type": "string" },
        "limit": { "type": "string" },
        "policy": { "type": "string" },
        "tooling": { "type": "string" },
        "enforcement": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
