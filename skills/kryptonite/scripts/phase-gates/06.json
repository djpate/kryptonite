{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase 6 Gate — Scope Confirmed",
  "description": "state.json stories array exists with basic structure per story",
  "type": "object",
  "required": ["epic", "state"],
  "properties": {
    "epic": {
      "type": "object",
      "required": ["name", "slug", "description", "status", "current_phase", "parties"],
      "properties": {
        "current_phase": { "type": "integer", "minimum": 6 },
        "parties": { "type": "array", "minItems": 1 }
      }
    },
    "state": {
      "type": "object",
      "required": ["stories"],
      "properties": {
        "stories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "statement", "party"],
            "properties": {
              "id": { "type": "string", "pattern": "^US-\\d{3,}[a-z]?$" },
              "type": { "type": "string", "enum": ["feature", "spike"] },
              "party": { "type": "string", "minLength": 1 },
              "statement": {
                "type": "object",
                "required": ["as_a", "i_want", "so_that"],
                "properties": {
                  "as_a": { "type": "string", "minLength": 1 },
                  "i_want": { "type": "string", "minLength": 1 },
                  "so_that": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    }
  }
}
