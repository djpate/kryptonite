{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase 1 Gate — General Description",
  "description": "epic.json exists with basic metadata. kryptonite_version enforced via semantic check.",
  "type": "object",
  "required": ["epic"],
  "properties": {
    "epic": {
      "type": "object",
      "required": ["name", "slug", "description", "status", "current_phase"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "status": { "const": "active" },
        "current_phase": { "type": "integer", "minimum": 1 },
        "kryptonite_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+" }
      }
    }
  }
}
