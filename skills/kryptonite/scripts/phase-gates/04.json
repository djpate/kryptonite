{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase 4 Gate — Parties Defined",
  "description": "All parties defined with name, description, and auth model",
  "type": "object",
  "required": ["epic"],
  "properties": {
    "epic": {
      "type": "object",
      "required": ["name", "slug", "description", "status", "current_phase", "parties"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "status": { "const": "active" },
        "current_phase": { "type": "integer", "minimum": 4 },
        "parties": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "description", "auth"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "auth": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
