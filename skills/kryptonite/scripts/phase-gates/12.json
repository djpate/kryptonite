{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase 12 Gate — Execution Complete",
  "description": "All non-cancelled/deferred stories are done with all gates passed. All waves completed.",
  "type": "object",
  "required": ["epic", "state"],
  "properties": {
    "epic": {
      "type": "object",
      "required": ["current_phase"],
      "properties": {
        "current_phase": { "type": "integer", "minimum": 12 }
      }
    },
    "state": {
      "type": "object",
      "required": ["stories", "waves"],
      "properties": {
        "stories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "status"],
            "if": {
              "properties": {
                "status": { "enum": ["done", "pending", "in_progress", "qa_validation", "in_review", "blocked"] }
              }
            },
            "then": {
              "properties": {
                "status": { "const": "done" },
                "dod_validation": {
                  "type": "object",
                  "required": ["all_passed"],
                  "properties": {
                    "all_passed": { "const": true }
                  }
                },
                "review_status": { "const": "approved" },
                "code_review_status": { "const": "approved" }
              },
              "required": ["status", "dod_validation", "review_status", "code_review_status"]
            }
          }
        },
        "waves": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["status"],
            "properties": {
              "status": { "const": "completed" }
            }
          }
        }
      }
    }
  }
}
