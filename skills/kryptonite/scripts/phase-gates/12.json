{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase 12 Gate — Execution Complete",
  "description": "All non-cancelled/deferred stories are done. All waves are complete with all four wave gates passing.",
  "type": "object",
  "required": ["epic", "state"],
  "properties": {
    "epic": {
      "type": "object",
      "required": ["current_phase"],
      "properties": {
        "current_phase": { "type": "integer", "minimum": 12 }
      }
    },
    "state": {
      "type": "object",
      "required": ["stories", "waves"],
      "properties": {
        "stories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "status"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["pending", "in_progress", "merged", "done", "blocked", "cancelled", "deferred"]
              }
            },
            "if": {
              "not": { "properties": { "status": { "enum": ["cancelled", "deferred"] } } }
            },
            "then": {
              "properties": { "status": { "const": "done" } }
            }
          }
        },
        "waves": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["status"],
            "properties": {
              "status": { "enum": ["complete", "blocked", "cancelled", "deferred"] }
            }
          }
        }
      }
    }
  }
}
