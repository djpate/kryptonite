{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase 8 Gate (Legacy) — DOD & Mocks Complete",
  "description": "Same as Phase 8 gate but without mock_phase requirement (field didn't exist in earlier versions)",
  "type": "object",
  "required": ["epic", "state", "repos"],
  "properties": {
    "epic": {
      "type": "object",
      "required": ["name", "slug", "description", "status", "current_phase", "parties", "technical_context"],
      "properties": {
        "current_phase": { "type": "integer", "minimum": 8 },
        "parties": { "type": "array", "minItems": 1 },
        "technical_context": { "type": "object", "minProperties": 1 }
      }
    },
    "state": {
      "type": "object",
      "required": ["stories"],
      "properties": {
        "stories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "party", "statement", "acceptance_criteria", "definition_of_done", "priority", "dependencies", "estimated_complexity", "repo"],
            "properties": {
              "id": { "type": "string", "pattern": "^US-\\d{3,}[a-z]?$" },
              "type": { "type": "string", "enum": ["feature", "spike"] },
              "party": { "type": "string", "minLength": 1 },
              "repo": { "type": "string", "minLength": 1 },
              "statement": {
                "type": "object",
                "required": ["as_a", "i_want", "so_that"]
              },
              "acceptance_criteria": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "definition_of_done": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["description", "validation"],
                  "properties": {
                    "description": { "type": "string", "minLength": 1 },
                    "validation": {
                      "type": "object",
                      "required": ["method"],
                      "properties": {
                        "method": { "type": "string", "enum": ["curl", "chrome_mcp", "test_suite", "file_exists"] }
                      }
                    }
                  }
                }
              },
              "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
              "dependencies": {
                "type": "array",
                "items": { "type": "string", "pattern": "^US-\\d{3,}[a-z]?$" }
              },
              "estimated_complexity": { "type": "string", "enum": ["trivial", "simple", "moderate", "complex", "very_complex"] }
            },
            "if": {
              "properties": { "has_mock": { "const": true } },
              "required": ["has_mock"]
            },
            "then": {
              "required": ["mock_approved"],
              "properties": {
                "mock_approved": { "const": true }
              }
            }
          }
        }
      }
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path", "stack"]
      }
    }
  }
}
